# Cloudflare Pages custom routes.
# This overrides the adapter-generated _routes.json so the worker runs
# for all page requests, enabling Accept: text/markdown content negotiation.
# Docs: https://developers.cloudflare.com/pages/functions/routing/

{
  "version": 1,
  "include": [
    "/*"
  ],
  "exclude": [
    "/_astro/*",
    "/.assetsignore",
    "/favicon.svg",
    "/og-default.png",
    "/og-default.svg",
    "/logos/*",
    "/about.md",
    "/blog/index.md",
    "/blog/the-agent-only-free-trial.md",
    "/contact.md",
    "/index.md",
    "/llms.txt",
    "/robots.txt",
    "/sitemap.xml",
    "/videos.md",
    "/writing.md"
  ]
}
