---
import { ArrowSquareOut } from '@phosphor-icons/react'
import type { WritingItem } from '@/data/writing'

interface Props {
  item: WritingItem
  showSite?: boolean
  compact?: boolean
}

const { item, showSite = true, compact = false } = Astro.props

const siteLabels: Record<WritingItem['site'], string> = {
  zuplo: 'Zuplo',
  nexmo: 'Vonage / Nexmo',
  sendgrid: 'SendGrid',
  'dev.to': 'dev.to',
  algolia: 'Algolia',
}

const formattedDate = item.date
  ? new Date(item.date).toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })
  : null
---

<a
  href={item.url}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    'group flex items-start justify-between gap-4 border-b border-[var(--color-border)] dark:border-[var(--color-border-dark)] last:border-0 hover:bg-[var(--color-surface)] dark:hover:bg-[var(--color-surface-dark)] -mx-3 px-3 rounded-md transition-colors',
    compact ? 'py-2.5' : 'py-4'
  ]}
>
  <div class="flex-1 min-w-0">
    <h3 class:list={[
      'group-hover:text-[var(--color-accent)] dark:group-hover:text-[var(--color-accent-dark)] transition-colors leading-snug text-[var(--color-text)] dark:text-[var(--color-text-dark)]',
      compact ? 'text-sm font-normal' : 'text-base font-medium'
    ]}>
      {item.title}
    </h3>
    <div class="flex items-center gap-2 mt-1.5">
      {showSite && (
        <span class="font-mono text-xs text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
          {siteLabels[item.site]}
        </span>
      )}
      {showSite && formattedDate && (
        <span class="text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">·</span>
      )}
      {formattedDate && (
        <span class="font-mono text-xs text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
          {formattedDate}
        </span>
      )}
    </div>
  </div>
  <ArrowSquareOut
    size={16}
    className="shrink-0 mt-1 text-[var(--color-muted)] dark:text-[var(--color-muted-dark)] group-hover:text-[var(--color-accent)] dark:group-hover:text-[var(--color-accent-dark)] transition-colors"
  />
</a>
