---
import { talks } from '../data/speaking';
---

<section>
  <h2>Speaking <span class="badge">{talks.length}</span></h2>
  <ul>
    {
      talks.map((talk) => (
        <li>
          <a href={talk.url} target="_blank" rel="noopener noreferrer">
            {talk.title}
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  section {
    min-width: 0;
  }

  h2 {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .badge {
    background: var(--color-badge-bg);
    color: var(--color-badge-text);
    font-size: 0.7rem;
    padding: 0.1em 0.5em;
    border-radius: 999px;
    font-weight: 600;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  li:last-child {
    border-bottom: none;
  }

  li a {
    font-size: 0.9375rem;
    line-height: 1.4;
  }
</style>
