---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SectionHeader from '@/components/SectionHeader.astro'
import BlogCard from '@/components/BlogCard.astro'
import { getCollection } from 'astro:content'
import { webSite, blog, breadcrumb } from '@/schemas'

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
---

<BaseLayout
  title="Blog"
  description="Writing by Martyn Davies on developer advocacy, tooling, and the evolving relationship between developers and the products they use."
  markdownUrl="/blog/index.md"
  schemas={[webSite(), blog(posts), breadcrumb([{ name: 'Home', url: '/' }, { name: 'Blog' }])]}
>
  <SectionHeader title="Blog" />

  {posts.length === 0 ? (
    <p class="text-sm text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">No posts yet.</p>
  ) : (
    <div>
      {posts.map(post => (
        <BlogCard
          title={post.data.title}
          date={post.data.date}
          excerpt={post.data.excerpt}
          slug={post.id.replace(/\.md$/, '')}
        />
      ))}
    </div>
  )}
</BaseLayout>
