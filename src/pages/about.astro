---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SectionHeader from '@/components/SectionHeader.astro'

const experience = [
  {
    company: 'Zuplo',
    roles: [
      {
        title: 'Developer Relations Lead',
        period: 'Aug 2024 – Present',
        description: 'Focused on how developers and AI coding agents adopt API infrastructure. Producing the full content stack across blog, video, newsletter, and social, backed by working demos and example projects. Leading GTM launches for MCP server support, AI Gateway, API Monetization and more.'
      }
    ]
  },
  {
    company: 'Superface',
    roles: [
      {
        title: 'Head of Developer Relations',
        period: 'May 2023 – May 2024',
        description: 'Led developer GTM working closely with the founders on product market fit as well as all developer asset creation from documentation to video content.'
      }
    ]
  },
  {
    company: 'Orbit',
    roles: [
      {
        title: 'Product Manager',
        period: 'May 2021 – Apr 2023',
        description: 'Managing product output for how users get their community data into Orbit — integrations, ETL partnerships, low/no-code solutions and the API — and then out again as valuable insight via reports, notifications and connections to other platforms.'
      }
    ]
  },
  {
    company: 'Vonage',
    roles: [
      {
        title: 'Director of Developer Education',
        period: 'Jan 2020 – Jun 2021',
        description: 'Leading the Developer Education team and strategy as part of the wider Product & Developer Experience department. Building a team of creative engineers to educate and inspire developers around an extensive communications API platform.'
      },
      {
        title: 'Senior Manager, Developer Relations & Developer Education',
        period: 'Jul 2018 – Jan 2020',
        description: null
      }
    ]
  },
  {
    company: 'Algolia',
    roles: [
      {
        title: 'Senior Developer Advocate',
        period: 'Jan 2018 – Jun 2018',
        description: null
      }
    ]
  },
  {
    company: 'Ignite Accelerator',
    roles: [
      {
        title: 'Programme Director',
        period: 'Sep 2015 – Dec 2017',
        description: 'Launched the Ignite Accelerator in London, raising funding for and successfully delivering two cohorts, investing over £500k in 19 teams. Responsible for overall programme strategy, technical due diligence, and founder support through the fundraising process.'
      }
    ]
  },
  {
    company: 'SendGrid',
    roles: [
      {
        title: 'Lead Developer Advocate, EMEA & APAC',
        period: 'Sep 2012 – Sep 2015',
        description: "Led the Community & Developer Relations team in EMEA as SendGrid's first non-US employee. Directed strategy around the SendGrid Accelerate Startup Programme, developer relations, and the European strategy for meetups, hackathons, conference participation and open source."
      }
    ]
  },
  {
    company: 'Six Two Productions',
    roles: [
      {
        title: 'Director of API Design',
        period: 'Mar 2011 – Aug 2012',
        description: 'Led a creative technology team building web and mobile applications with heavy API dependencies. Acted in an advisory capacity to major labels on open data and API strategy. Client work included Universal Music Group, Warner Music, Sony Music, and others.'
      }
    ]
  },
  {
    company: 'Universal Music Group',
    roles: [
      {
        title: 'Product Manager, Innovation',
        period: 'Jun 2010 – Jun 2011',
        description: 'Leading mobile application commissioning and development across B2B and B2C technology centrally for the 5 major label groups that make up UMG. Product Manager for UK mobile operations, digital technology joint ventures, and 3rd party API integrations.'
      }
    ]
  },
  {
    company: 'BBC Audio & Music Interactive',
    roles: [
      {
        title: 'Product Manager',
        period: 'Mar 2008 – Jun 2010',
        description: 'Developed the outline and led the team that built the BBC Introducing technology platform, which has launched several number one artists. Focused on product management and application of new technologies to enhance BBC Music offerings, and managed relationships between BBC Music and third party start-ups.'
      }
    ]
  },
]
---

<BaseLayout
  title="About"
  description="About Martyn Davies — background, experience, and career history in developer advocacy and product management."
>
  <SectionHeader title="About" />

  <div class="mb-12">
    <p class="text-base text-[var(--color-text)] dark:text-[var(--color-text-dark)] leading-relaxed max-w-xl">
      Multi-year experience leading Developer Advocacy, Education, Community Management, and Product
      Management at companies large and small. I've been building, leading and enjoying being a part
      of forward-thinking advocacy teams from 1 person to 40+ since 2012.
    </p>
  </div>

  <section class="mb-12">
    <SectionHeader title="Experience" />

    <div class="space-y-0">
      {experience.map((entry, i) => (
        <div class:list={['py-6', i < experience.length - 1 ? 'border-b border-[var(--color-border)] dark:border-[var(--color-border-dark)]' : '']}>
          <p class="font-mono text-xs text-[var(--color-accent)] dark:text-[var(--color-accent-dark)] mb-3">
            {entry.company}
          </p>
          <div class="space-y-4">
            {entry.roles.map(role => (
              <div>
                <div class="flex items-baseline justify-between gap-4 mb-1">
                  <h3 class="text-sm font-medium text-[var(--color-text)] dark:text-[var(--color-text-dark)]">
                    {role.title}
                  </h3>
                  <span class="font-mono text-xs text-[var(--color-muted)] dark:text-[var(--color-muted-dark)] shrink-0">
                    {role.period}
                  </span>
                </div>
                {role.description && (
                  <p class="text-sm text-[var(--color-muted)] dark:text-[var(--color-muted-dark)] leading-relaxed">
                    {role.description}
                  </p>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section>
    <SectionHeader title="Focus areas" />
    <ul class="grid grid-cols-2 gap-2">
      {[
        'Developer Advocacy',
        'Developer Education',
        'Community Management',
        'Product Management',
        'Developer Experience',
        'API Products',
        'Technical Writing',
        'Team Leadership',
      ].map(area => (
        <li class="flex items-center gap-2 text-sm text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
          <span class="text-[var(--color-accent)] dark:text-[var(--color-accent-dark)] font-mono text-xs">→</span>
          {area}
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
