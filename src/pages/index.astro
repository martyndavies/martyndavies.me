---
import Layout from '../layouts/Layout.astro';
import WritingList from '../components/WritingList.astro';
import SpeakingList from '../components/SpeakingList.astro';
---

<Layout>
  <main>
    <header>
      <h1>Martyn Davies</h1>
      <p class="subtitle">Developer Relations &middot; Writing &middot; Speaking</p>
    </header>
    <hr />
    <div class="grid">
      <WritingList />
      <SpeakingList />
    </div>
  </main>
</Layout>

<style>
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  header {
    text-align: center;
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 0.4rem;
  }

  .subtitle {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    margin: 0;
  }

  hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0 0 2.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
